# ── QuantAI Backend Environment Configuration ─────────────────────────────────
# Copy this file to .env and fill in your values.
# All fields have sensible defaults — only API keys need to be set.

# App
DEBUG=false

# CORS — set to your frontend domain in production
# ALLOWED_ORIGINS=["https://yourdomain.com","http://localhost:3000"]
ALLOWED_ORIGINS=["*"]

# NewsAPI (optional — improves news coverage; free tier at newsapi.org)
# NEWS_API_KEY=your_newsapi_key_here

# Alpha Vantage (optional — fallback data source; free at alphavantage.co)
# ALPHA_VANTAGE_KEY=your_av_key_here

# Cache TTLs (seconds)
NEWS_CACHE_TTL_SECONDS=900
PREDICTION_CACHE_TTL_SECONDS=300

# Monte Carlo paths (reduce to 1000 on low-RAM deployments)
MC_PATHS=10000
